# Copy this file to .env and adjust if needed
# No API keys required - everything runs locally!

# Path to your documents folder (default: ./docs)
DOCS_FOLDER=./docs

# ChromaDB persistence folder (default: ./chroma_db)
CHROMA_DB_FOLDER=./chroma_db

# Ollama model for chat (must be pulled first)
CHAT_MODEL=deepseek-r1:7b

# Ollama model for embeddings (must be pulled first)
EMBED_MODEL=nomic-embed-text

# Number of document chunks to retrieve per query
TOP_K=5
